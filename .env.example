# ArchViber Environment Variables

# Third-party API relay (optional, for routing through a proxy/relay)
# RELAY_API_BASE_URL=https://your-relay.example.com
# RELAY_API_KEY=sk-your-key
# USE_RELAY=false

# Fix ECONNRESET on Windows when connecting through proxy with self-signed certs
# NODE_TLS_REJECT_UNAUTHORIZED=0
