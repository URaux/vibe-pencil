# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/output/
/workspace/
.planning/*
!.planning/phase1/
design/
_pf_parts/
promptfolio_payload.json

# Generated files
.graphify_*
graphify-out/
src/graphify-out/
test-results/

# Local session store (chat history persisted on disk)
/data/

# Runtime project state (IR, brainstorm-state, audit logs) — written at runtime, not source
.archviber/

# Demo-run screenshots — heavy PNGs, not needed for code review
.planning/phase1/demo-runs/screenshots/
tests/demo/screenshots/
